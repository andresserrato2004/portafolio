---
import "../styles/global.css";
import Analytics from "@vercel/analytics/astro";

type Props = {
  title?: string;
  description?: string;
  lang?: "es" | "en";
};

const {
  title = "Portafolio | Software Developer + Cybersecurity",
  description = "Portafolio profesional en Astro + HeroUI con enfoque en desarrollo de software y ciberseguridad.",
  lang = "es",
} = Astro.props as Props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <Analytics />
    <slot />
  </body>
</html>
