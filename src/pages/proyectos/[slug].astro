---
import MainLayout from "../../layouts/MainLayout.astro";
import { projects } from "../../data/projects";

export const getStaticPaths = () =>
  projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));

const { project } = Astro.props;

if (!project) {
  return Astro.redirect("/");
}
---

<MainLayout
  title={`${project.title} | Portafolio Andres Serrato`}
  description={project.description}
>
  <main class="min-h-screen bg-[var(--bg)] px-4 py-10 text-[var(--text)] md:px-8">
    <div class="mx-auto w-full max-w-6xl space-y-8">
      <a
        href="/"
        class="inline-flex items-center gap-2 rounded-full border border-[var(--line)] bg-[var(--surface)] px-4 py-2 text-xs text-[var(--text-muted)] transition-colors hover:text-white"
      >
        ← Volver al portafolio
      </a>

      <section class="rounded-2xl border border-[var(--line)] bg-[var(--surface)] p-6 md:p-8">
        <p class="mb-2 text-xs uppercase tracking-[0.12em] text-[var(--accent)]">Proyecto</p>
        <h1 class="text-balance text-3xl font-bold text-white md:text-5xl">{project.title}</h1>
        <p class="mt-4 max-w-4xl text-[var(--text-muted)]">{project.longDescription}</p>
        <div class="mt-5 flex flex-wrap gap-2">
          {project.stack.map((tech: string) => (
            <span class="rounded-full border border-[var(--line)] bg-[var(--surface-2)] px-3 py-1 text-[10px] uppercase tracking-[0.1em] text-[var(--text-muted)]">
              {tech}
            </span>
          ))}
        </div>
      </section>

      <section class="grid gap-6 lg:grid-cols-[1.2fr_0.8fr]">
        <article class="rounded-2xl border border-[var(--line)] bg-[var(--surface)] p-6">
          <h2 class="text-xl font-semibold text-white">Arquitectura</h2>
          <ul class="mt-4 space-y-2">
            {project.architecture.map((item: string) => (
              <li class="rounded-lg border border-[var(--line)] bg-[var(--surface-2)] p-3 text-sm text-[var(--text-muted)]">
                {item}
              </li>
            ))}
          </ul>
        </article>

        <article class="rounded-2xl border border-[var(--line)] bg-[var(--surface)] p-6">
          <h2 class="text-xl font-semibold text-white">Impacto & seguridad</h2>
          <p class="mt-3 text-sm text-[var(--text-muted)]">
            <span class="text-white">Impacto:</span> {project.impact}
          </p>
          <div class="mt-3 flex flex-wrap gap-2">
            {project.securityNotes.map((note: string) => (
              <span class="rounded-full border border-[var(--line)] px-3 py-1 text-[10px] uppercase tracking-[0.1em] text-[var(--primary)]">
                {note}
              </span>
            ))}
          </div>
          <a
            href={project.githubUrl}
            target="_blank"
            rel="noreferrer"
            class="mt-5 inline-flex rounded-full border border-[var(--line)] bg-[var(--surface-2)] px-4 py-2 text-xs text-white"
          >
            Ver repositorio
          </a>
        </article>
      </section>

      <section class="rounded-2xl border border-[var(--line)] bg-[var(--surface)] p-6">
        <h2 class="text-xl font-semibold text-white">Evidencias (ejecución e imágenes)</h2>
        <p class="mt-2 text-sm text-[var(--text-muted)]">
          Este espacio está listo para que agregues screenshots, videos y diagramas por proyecto.
        </p>
        <div class="mt-4 grid gap-4 md:grid-cols-2">
          {project.executionAssets.map((asset: { label: string; pathHint: string }) => (
            <div class="rounded-xl border border-dashed border-[var(--line)] bg-[var(--surface-2)] p-4">
              <p class="text-sm font-medium text-white">{asset.label}</p>
              <p class="mt-2 text-xs text-[var(--text-muted)]">Ruta sugerida: <code>{asset.pathHint}</code></p>
            </div>
          ))}
        </div>
      </section>

      <section class="rounded-2xl border border-[var(--line)] bg-[var(--surface)] p-6">
        <h2 class="text-xl font-semibold text-white">Notas adicionales</h2>
        <ul class="mt-4 space-y-2">
          {project.extraContext.map((note: string) => (
            <li class="rounded-lg border border-[var(--line)] bg-[var(--surface-2)] p-3 text-sm text-[var(--text-muted)]">
              {note}
            </li>
          ))}
        </ul>
      </section>
    </div>
  </main>
</MainLayout>
